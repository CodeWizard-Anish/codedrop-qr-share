{
  "name": "codedrop-qr",
  "displayName": "CodeDrop QR Share",
  "description": "Instantly send files from VS Code to your phone using a QR code.",
  "version": "1.1.0",
  "publisher": "anishraj",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "qr",
    "file transfer",
    "send to phone",
    "qr sharing",
    "developer tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeWizard-Anish/codedrop-qr-share"
  },
  "bugs": {
    "url": "https://github.com/CodeWizard-Anish/codedrop-qr-share/issues"
  },
  "activationEvents": [
    "onCommand:codedrop.sendFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codedrop.sendFile",
        "title": "CodeDrop: Send File to Phone"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "codedrop.sendFile",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "form-data": "^4.0.5",
    "qrcode": "^1.5.4"
  }
}
